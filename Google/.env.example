# Google Calendar environment variables for PAIGE
#
# Copy the relevant keys into the repo root `.env` (recommended), OR set an explicit dotenv file:
#   PAIGE_DOTENV_PATH=/absolute/path/to/your/.env
#
# Required: OAuth client id for the OAuth "limited-input device" flow
GOOGLE_OAUTH_CLIENT_ID=

# Optional: some OAuth client types require a secret
GOOGLE_OAUTH_CLIENT_SECRET=

# Token storage (defaults shown)
GOOGLE_TOKEN_PATH=./tokens.json
GOOGLE_PENDING_PATH=./.calendar_device_flow.json

# How long `connect_calendar()` should poll for device-flow completion
GOOGLE_CONNECT_WAIT_S=60

# Calendar permissions
# Read-only (default): can list/search events
#GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.readonly
# Read-write: can create/update/delete events (requires disconnect + reconnect)
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.readonly

# Used when creating/updating timed events without an explicit timezone.
# Set to an IANA timezone like: Europe/London, America/New_York
GOOGLE_CALENDAR_TIMEZONE=UTC
